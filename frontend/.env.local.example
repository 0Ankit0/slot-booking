# backend.localhost resolves on the host and is remapped inside Docker so
# the web app can use one API base URL for both host and compose workflows.
NEXT_PUBLIC_APP_NAME=Slot Booking
NEXT_PUBLIC_API_URL=http://backend.localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://backend.localhost:8000

# Analytics
# Browser-safe values only. Keep vendor secrets in backend/.env instead.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=posthog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
