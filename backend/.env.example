PYTHONPATH=.
# Config classes used throughout the project:
# - bootstrap-only: env / deployment only, needed before DB-backed overrides exist
# - runtime-editable: env baseline plus optional generalsetting override
# - public runtime: backend allowlist only, safe for discovery APIs
# - secret-only: env / secret manager only, never public and never runtime-editable
# -----------------------------------------------------------------------------
# Core settings
# -----------------------------------------------------------------------------
PROJECT_NAME=Slot Booking
API_V1_STR=/api/v1
SECRET_KEY=__AUTO_GENERATE_SECRET_KEY__
# Optional pepper added to password hashing (recommended to keep this secret and stable across deployments)
PASSWORD_PEPPER=__AUTO_GENERATE_PASSWORD_PEPPER__
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_COOKIE=access_token
REFRESH_TOKEN_COOKIE=refresh_token
SECURE_COOKIES=False

# Account security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
REQUIRE_EMAIL_VERIFICATION=False
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=False

# Debug / runtime
DEBUG=True
TESTING=False
APP_ENV=local
APP_INSTANCE_NAME=slot-booking
APP_REGION=local

# Logging / observability
LOG_LEVEL=INFO
LOG_PERSIST_MIN_LEVEL=INFO
# Supported outputs: console, database, web, file
# "web" uses the persisted database-backed log stream for the admin log view
LOG_OUTPUTS=console,database,web
LOG_FILE_PATH=logs/application.log
LOG_RETENTION_DAYS=7
LOG_SQL_QUERIES=False

# -----------------------------------------------------------------------------
# Feature toggles
# -----------------------------------------------------------------------------
FEATURE_AUTH=True
FEATURE_MULTITENANCY=True
FEATURE_NOTIFICATIONS=True
FEATURE_WEBSOCKETS=True
FEATURE_FINANCE=True
FEATURE_ANALYTICS=True
FEATURE_SOCIAL_AUTH=True
FEATURE_MAPS=False

# CORS
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://frontend.localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,backend.localhost,backend,frontend,test,testserver
# Reverse proxy addresses or "*" for local/dev proxy chains
PROXY_TRUSTED_HOSTS=*
FORWARDED_ALLOW_IPS=*

# -----------------------------------------------------------------------------
# Database settings
# -----------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__AUTO_GENERATE_POSTGRES_PASSWORD__
POSTGRES_DB=slot_booking
# Leave blank to follow the DEBUG-based default builder.
DATABASE_URL=
SYNC_DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# Redis / Celery settings
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
# Optional overrides:
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=1800
CELERY_RESULT_EXPIRES=3600
# Leave blank to follow DEBUG by default; set explicitly for workers/environments
CELERY_TASK_ALWAYS_EAGER=
CELERY_QUEUE_DEFAULT=default

# -----------------------------------------------------------------------------
# Email settings
# -----------------------------------------------------------------------------
EMAIL_ENABLED=False
EMAIL_PROVIDER=smtp
EMAIL_FALLBACK_PROVIDERS=resend,ses
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@example.com
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@example.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=noreply@example.com

# -----------------------------------------------------------------------------
# Frontend / server
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
SERVER_HOST=http://localhost:8000
COOKIE_DOMAIN=
# One of: lax, strict, none
COOKIE_SAMESITE=lax
HTTP_TIMEOUT_SECONDS=15
HTTP_RETRY_COUNT=1
HTTP_BACKOFF_SECONDS=0.5
WS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend.localhost:3000
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_MAX_IDLE_SECONDS=90

# -----------------------------------------------------------------------------
# Media / file uploads
# -----------------------------------------------------------------------------
MEDIA_DIR=media
MEDIA_URL=/media
STORAGE_BACKEND=local
# Optional public base URL for media. Defaults to SERVER_HOST + MEDIA_URL for local storage.
MEDIA_BASE_URL=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_USE_PATH_STYLE=False
MAX_AVATAR_SIZE_MB=5

# -----------------------------------------------------------------------------
# Maps
# -----------------------------------------------------------------------------
MAP_PROVIDER=osm
OSM_MAPS_ENABLED=True
GOOGLE_MAPS_ENABLED=False
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=
MAP_DEFAULT_LATITUDE=27.7172
MAP_DEFAULT_LONGITUDE=85.3240
MAP_DEFAULT_ZOOM=13

# -----------------------------------------------------------------------------
# Payment gateway settings
# -----------------------------------------------------------------------------
KHALTI_ENABLED=False
KHALTI_SECRET_KEY=
KHALTI_BASE_URL=https://dev.khalti.com/api/v2/

ESEWA_ENABLED=False
ESEWA_SECRET_KEY=
ESEWA_MERCHANT_CODE=
ESEWA_BASE_URL=https://rc-epay.esewa.com.np/api/epay/

STRIPE_ENABLED=False
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_ENABLED=False
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------
PUSH_ENABLED=False
PUSH_PROVIDER=webpush
PUSH_FALLBACK_PROVIDERS=fcm,onesignal
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@example.com
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_WEB_VAPID_KEY=
FCM_API_KEY=
FCM_APP_ID=
FCM_MESSAGING_SENDER_ID=
FCM_AUTH_DOMAIN=
FCM_STORAGE_BUCKET=
FCM_MEASUREMENT_ID=
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_FILE=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
ONESIGNAL_WEB_APP_ID=

# -----------------------------------------------------------------------------
# SMS / messaging
# -----------------------------------------------------------------------------
SMS_ENABLED=False
SMS_PROVIDER=twilio
SMS_FALLBACK_PROVIDERS=vonage
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Social auth
# -----------------------------------------------------------------------------
GOOGLE_ENABLED=False
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_ENABLED=False
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

FACEBOOK_ENABLED=False
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

SOCIAL_AUTH_REDIRECT_URL=http://localhost:3000/auth-callback

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
ANALYTICS_ENABLED=False
ANALYTICS_PROVIDER=posthog
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
MIXPANEL_PROJECT_TOKEN=
MIXPANEL_API_SECRET=
MIXPANEL_API_HOST=https://api.mixpanel.com

# -----------------------------------------------------------------------------
# Operational throttles / detection
# -----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SIGNUP=3/hour
RATE_LIMIT_PASSWORD_RESET=3/hour
FAILED_LOGIN_BURST_THRESHOLD=5
FAILED_LOGIN_BURST_WINDOW_MINUTES=30
TOKEN_CHURN_THRESHOLD=3
TOKEN_CHURN_WINDOW_MINUTES=10
RATE_LIMIT_SPIKE_THRESHOLD=10
RATE_LIMIT_SPIKE_WINDOW_MINUTES=10
ERROR_SPIKE_THRESHOLD=5
ERROR_SPIKE_WINDOW_MINUTES=10
